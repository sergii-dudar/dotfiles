#!/usr/bin/env bash
# Display disk usage for both `/` and `/home`.

. "$HOME"/dotfiles/bin/slstatus/colorscheme

temp=$(sensors | awk '/Core 0/ {print $3}' | sed 's/[^0-9]*\([0-9]*\)\..*/\1/')

icon_fg="8caaee"
icon="Ôčč"

if [ "$temp" -lt 25 ]; then
    icon_fg="8caaee"
    icon="Ôčč"
elif [ "$temp" -lt 50 ]; then
    icon_fg="8caaee"
    icon="Ôčä"
elif [ "$temp" -lt 65 ]; then
    icon_fg="e5c890"
    icon="ÔčČ"
elif [ "$temp" -lt 80 ]; then
    icon_fg="e78284"
    icon="ÔčČ"
else
    icon_fg="ff5555"
    icon="Ôčá"
fi

echo " ^fg($icon_fg)$icon‚ÄČ^fg($FG_COLOR)$temp^fg(6272a4)¬įC $SPLIT"
