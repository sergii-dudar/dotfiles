# Calculate CPU usage percentage
cpu_percentage=$(awk '/^cpu / {
  total=0;
  idle=0;
  count=0;
  for(i=2; i<=NF; i++) total+=$i;
  idle+=$5;
  count++;
  if (count > 0) {
    avg_usage = ((total - idle) * 100) / total;
  }
} END { printf "%.0f\n", avg_usage }' /proc/stat)

echo " ^fg(8caaee)  ^fg($FG_COLOR)$cpu_percentage^fg(6272a4)% $SPLIT"