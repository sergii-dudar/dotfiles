#!/usr/bin/env bash

. "$HOME"/dotfiles/bin/slstatus/colorscheme

declare -A lmap
lmap["Ukrainian"]="UA"
lmap["English (US)"]="US"
lmap["ua"]="UA"
lmap["us"]="US"

k_layout_icon=" "
k_layout=$(cat /tmp/dwl-keymap 2>/dev/null)
k_display="${lmap[$k_layout]:-$k_layout}"

echo " ^fg(8caaee)$k_layout_icon ^fg(cba6f7)${k_display}^fg()^bg()  $SPLIT"
