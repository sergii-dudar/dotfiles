#!/usr/bin/env bash
# Display disk usage for both `/` and `/home`.

case "$BLOCK_BUTTON" in
    1) setsid --fork foot --app-id=com.term.float.htop_info -e btop ;;
    6) setsid --fork foot -e nvim "$0" ;;
        # *) notify-send "not action on: button -- $BLOCK_BUTTON" ;;
esac

. "$HOME"/dotfiles/bin/dwl/colorscheme

temp=$(sensors | awk '/Core 0/ {print $3}' | sed 's/[^0-9]*\([0-9]*\)\..*/\1/')

icon_fg="8caaee"
icon="п‹‹"

if [ "$temp" -lt 25 ]; then
    icon_fg="8caaee"
    icon="п‹‹"
elif [ "$temp" -lt 50 ]; then
    icon_fg="8caaee"
    icon="п‹Љ"
elif [ "$temp" -lt 65 ]; then
    icon_fg="e5c890"
    icon="п‹‰"
elif [ "$temp" -lt 80 ]; then
    icon_fg="e78284"
    icon="п‹‰"
else
    icon_fg="ff5555"
    icon="п‹‡"
fi

echo " ^fg($icon_fg)$iconвЂ‰^fg($FG_COLOR)$temp^fg(6272a4)В°C $SPLIT"
