#!/usr/bin/env bash

case $BLOCK_BUTTON in
    6) setsid --fork foot -e nvim "$0" ;;
        # *) notify-send "not action on: button -- $BLOCK_BUTTON" ;;
esac

. "$HOME"/dotfiles/bin/dwl/colorscheme

declare -A lmap
lmap["Ukrainian"]="UA"
lmap["English (US)"]="US"
lmap["ua"]="UA"
lmap["us"]="US"

k_layout_icon=" "
k_layout=$(cat /tmp/dwl-keymap 2>/dev/null)
k_display="${lmap[$k_layout]:-$k_layout}"

if [ "$k_layout" == "Ukrainian" ]; then
    notify-send "Lang: UA ""🇺🇦" -t 700
else
    notify-send "Lang: US ""🇺🇸" -t 700
fi

echo " ^fg(8caaee)$k_layout_icon ^fg(cba6f7)${k_display}^fg()^bg()  $SPLIT"
