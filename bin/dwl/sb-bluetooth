#!/usr/bin/env bash
# Display bluetooth status and connected device.
# Based on waybar bluetooth module.
# Dependencies: sudo pacman -S bluez-utils

. "$HOME"/dotfiles/bin/dwl/colorscheme

# Check if bluetoothctl is available
command -v bluetoothctl &>/dev/null || exit 0

# Check if bluetooth controller is powered on
powered="$(bluetoothctl show 2>/dev/null | grep -i 'Powered:' | awk '{print $2}')"

if [ "$powered" != "yes" ]; then
    echo " ^fg(6272a4)󰂲^fg() $SPLIT"
    exit 0
fi

# Get connected devices
connected_devices="$(bluetoothctl devices Connected 2>/dev/null)"

if [ -z "$connected_devices" ]; then
    echo " ^fg(51afef)󰂯^fg() $SPLIT"
    exit 0
fi

