#!/usr/bin/env bash
# Display bluetooth status and connected device.
# Based on waybar bluetooth module.
# Dependencies: sudo pacman -S bluez-utils

case "$BLOCK_BUTTON" in
    1) setsid --fork foot --app-id=com.term.float.bluetooth -e bluetui ;;
    6) setsid --fork foot -e nvim "$0" ;;
        # *) notify-send "not action on: button -- $BLOCK_BUTTON" ;;
esac

. "$HOME"/dotfiles/bin/dwl/colorscheme

# Check if bluetoothctl is available
command -v bluetoothctl &>/dev/null || exit 0

# Check if bluetooth controller is powered on
powered="$(bluetoothctl show 2>/dev/null | grep -i 'Powered:' | awk '{print $2}')"

if [ "$powered" != "yes" ]; then
    echo " ^fg(6272a4)󰂲^fg() $SPLIT"
    exit 0
fi

# Get connected devices
connected_devices="$(bluetoothctl devices Connected 2>/dev/null)"

if [ -z "$connected_devices" ]; then
    echo " ^fg(51afef)󰂯^fg() $SPLIT"
    exit 0
fi

# Show first connected device name
# device_alias="$(echo "$connected_devices" | head -1 | cut -d' ' -f3-)"

# Truncate long device names
# if [ "${#device_alias}" -gt 15 ]; then
#     device_alias="${device_alias:0:12}..."
# fi

# echo " ^fg(4db5bd)󰂱^fg() ^fg(5699af)${device_alias}^fg() $SPLIT"
# echo " ^fg(4db5bd)󰂱^fg() $SPLIT"

battery="$(bluetoothctl info 2>/dev/null | grep "Battery Percentage" | awk -F '[()]' '{print $2}')"
if [ -n "$battery" ]; then
    # echo " ^fg(4db5bd)󰂱^fg() ^fg(5699af)${battery}%^fg() $SPLIT"
    echo " ^fg(8caaee)󰂱^fg() ^fg($FG_COLOR)$battery^fg(6272a4)% $SPLIT"
else
    echo " ^fg(4db5bd)󰂱^fg() $SPLIT"
fi